# CommonGround Parent App Environment Variables
# Copy this file to .env.local and fill in the values

# ==============================================================================
# API Configuration
# ==============================================================================

# Backend API URL
EXPO_PUBLIC_API_URL=http://localhost:8000

# App Configuration
EXPO_PUBLIC_APP_NAME=CommonGround

# ==============================================================================
# Supabase Configuration
# ==============================================================================

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ==============================================================================
# OAuth Configuration (Google Sign-In)
# ==============================================================================

# Get these from Google Cloud Console > APIs & Services > Credentials
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# ==============================================================================
# Expo / EAS Configuration
# ==============================================================================

# EAS Project ID (from expo.dev)
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id

# ==============================================================================
# Daily.co (Video Calls)
# ==============================================================================

EXPO_PUBLIC_DAILY_API_KEY=your-daily-api-key

# ==============================================================================
# Stripe (Payments)
# ==============================================================================

EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# ==============================================================================
# Feature Flags
# ==============================================================================

EXPO_PUBLIC_ENABLE_BIOMETRIC=true
EXPO_PUBLIC_ENABLE_OAUTH=true
EXPO_PUBLIC_ENABLE_MFA=true
