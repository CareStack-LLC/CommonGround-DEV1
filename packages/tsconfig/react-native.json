{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "CommonGround React Native / Expo",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-native",
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true
  }
}
